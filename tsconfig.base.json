{
  "compilerOptions": {
    "composite": true,
    "paths": {
      "@metrics-platform/core-application": [
        "libs/core-application/src/index.ts"
      ],
      "@metrics-platform/core-domain": ["libs/core-domain/src/index.ts"],
      "@metrics-platform/core-infrastructure": [
        "libs/core-infrastructure/src/index.ts"
      ],
      "@metrics-platform/core-shared": ["libs/core-shared/src/index.ts"],
      "@metrics-platform/marketing-application": [
        "libs/marketing-application/src/index.ts"
      ],
      "@metrics-platform/marketing-infrastructure": [
        "libs/marketing-infrastructure/src/index.ts"
      ],
      "@metrics-platform/marketing-plugins": [
        "libs/marketing-plugins/src/index.ts"
      ]
    },
    "declarationMap": true,
    "emitDeclarationOnly": false,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["development"]
  }
}
