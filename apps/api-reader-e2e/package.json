{
  "name": "@metrics-platform/api-reader-e2e",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "implicitDependencies": [
      "@metrics-platform/api-reader"
    ],
    "targets": {
      "e2e": {
        "executor": "@nx/jest:jest",
        "outputs": [
          "{projectRoot}/test-output/jest/coverage"
        ],
        "options": {
          "jestConfig": "api-reader-e2e/jest.config.ts",
          "passWithNoTests": true
        },
        "dependsOn": [
          "@metrics-platform/api-reader:build",
          "@metrics-platform/api-reader:serve"
        ]
      }
    }
  }
}
